rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - username: string (required)
    //   - email: string (required)
    //   - role: string (enum: user, admin) (required)
    //   - createdAt: string (required)
    //
    // Collection: products
    // Document ID: productId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - price: number (required)
    //   - description: string (required)
    //   - imageURLs: list (required)
    //   - category: string (required)
    //   - stockStatus: string (enum: in-stock, out-of-stock) (required)
    //   - createdAt: string (required)
    //
    // Collection: orders
    // Document ID: orderId
    // Fields:
    //   - id: string (required)
    //   - products: list (required)
    //   - totalPrice: number (required)
    //   - customerName: string (required)
    //   - phone: string (required)
    //   - address: string (required)
    //   - notes: string (optional)
    //   - status: string (enum: Pending, Confirmed, Delivered) (required)
    //   - userId: string (required)
    //   - createdAt: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "msfragrances10@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['id', 'name', 'username', 'email', 'role', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'name', 'username', 'email', 'role', 'createdAt']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             data.createdAt is string;
    }

    function isValidProduct(data) {
      return hasRequiredFields(['name', 'price', 'description', 'imageURLs', 'category', 'stockStatus', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'name', 'price', 'description', 'imageURLs', 'category', 'stockStatus', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.description is string && data.description.size() < 2000 &&
             data.imageURLs is list &&
             data.category is string &&
             data.stockStatus in ['in-stock', 'out-of-stock'] &&
             data.createdAt is string;
    }

    function isValidOrder(data) {
      return hasRequiredFields(['products', 'totalPrice', 'customerName', 'phone', 'address', 'status', 'userId', 'createdAt']) &&
             hasOnlyAllowedFields(['id', 'products', 'totalPrice', 'customerName', 'phone', 'address', 'notes', 'status', 'userId', 'createdAt', 'serverTimestamp']) &&
             data.products is list &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.phone is string &&
             data.address is string &&
             data.status in ['Pending', 'Confirmed', 'Out for Delivery', 'Delivered', 'Cancelled'] &&
             data.userId is string &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId && isValidOrder(request.resource.data) && request.resource.data.status == 'Pending';
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
