{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and role.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the user." },
        "name": { "type": "string", "description": "The user's full name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role in the application." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The timestamp when the user was created." }
      },
      "required": ["id", "name", "email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Fragrance product details.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the product." },
        "name": { "type": "string", "description": "The name of the fragrance." },
        "price": { "type": "number", "description": "The price of the product." },
        "description": { "type": "string", "description": "A detailed description of the fragrance." },
        "imageURLs": { "type": "array", "items": { "type": "string" }, "description": "A list of image URLs for the product." },
        "category": { "type": "string", "description": "The category of the fragrance (e.g., Woody, Floral, Fresh)." },
        "stockStatus": { "type": "string", "enum": ["in-stock", "out-of-stock"], "description": "The current stock status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The timestamp when the product was added." }
      },
      "required": ["id", "name", "price", "description", "imageURLs", "category", "stockStatus", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the order." },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" },
              "imageURL": { "type": "string" }
            }
          }
        },
        "totalPrice": { "type": "number", "description": "The total price of the order." },
        "customerName": { "type": "string", "description": "The name of the customer." },
        "phone": { "type": "string", "description": "The customer's phone number." },
        "address": { "type": "string", "description": "The delivery address." },
        "notes": { "type": "string", "description": "Optional notes from the customer." },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Delivered"], "description": "The current status of the order." },
        "userId": { "type": "string", "description": "The ID of the user who placed the order." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The timestamp when the order was placed." }
      },
      "required": ["id", "products", "totalPrice", "customerName", "phone", "address", "status", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of fragrance products."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders."
    }
  }
}
